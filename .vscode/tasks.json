{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build",
            "type": "shell",
            "command": "cargo",
            "args": ["build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo build --release",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "--release"],
            "group": "build",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo test",
            "type": "shell",
            "command": "cargo",
            "args": ["test"],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$rustc"],
            "options": {
                "env": {
                    "RUST_BACKTRACE": "1"
                }
            }
        },
        {
            "label": "cargo clippy",
            "type": "shell",
            "command": "cargo",
            "args": ["clippy", "--all-targets", "--all-features"],
            "group": "build",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo fmt",
            "type": "shell",
            "command": "cargo",
            "args": ["fmt"],
            "group": "build"
        },
        {
            "label": "cargo doc",
            "type": "shell",
            "command": "cargo",
            "args": ["doc", "--open"],
            "group": "build"
        },
        {
            "label": "Clean Build Artifacts",
            "type": "shell",
            "command": "cargo",
            "args": ["clean"],
            "group": "build"
        },
        {
            "label": "Check All",
            "type": "shell",
            "command": "cargo",
            "args": ["check", "--all-targets"],
            "group": "build",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Full Quality Check",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cargo fmt --all -- --check && cargo clippy --all-targets -- -D warnings && cargo test"
            ],
            "group": "test",
            "problemMatcher": ["$rustc"]
        }
    ]
}
